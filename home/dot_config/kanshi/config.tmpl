output "GIGA-BYTE TECHNOLOGY CO., LTD. Gigabyte M32U 0x01010101" {
  mode 3840x2160@143.988
  scale 1.5
  alias $HOME
}

{{- if eq .chezmoi.hostname "PHOENIX-PCLIN01" }}
profile single {
  output $HOME enable
}
{{- else if eq .chezmoi.hostname "PHOENIX-LTLIN01" }}
output "BOE 0x0AA8 Unknown" {
  mode 3072x1920@120.002
  scale 1.5
  alias $INTERNAL
}

output "ASUSTek COMPUTER INC VG34VQL3A S3LMDW009542" {
  mode 3440x1440@143.975
  scale 1.0
  alias $HOLISTICS
}

output "Dell Inc. DELL U2419H JW3TC23" {
  mode 1920x1080@60.000
  scale 1.0
  alias $HOME_DAKLAK
}

profile internal-only {
  output $INTERNAL enable
}

profile dual-holistics {
  output $INTERNAL disable
  output $HOLISTICS enable
}

profile home-daklak {
  output $INTERNAL disable
  output $HOME_DAKLAK enable
}
{{- end }}
